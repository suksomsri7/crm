generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH & MULTI-TENANT
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  fullName      String
  avatarUrl     String?
  isSuperAdmin  Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userBrands    UserBrand[]
  auditLogs     AuditLog[]
  activities    Activity[]
  notifications Notification[]
  assignedLeads Lead[]         @relation("AssignedTo")
  createdLeads  Lead[]         @relation("CreatedBy")
  tickets       Ticket[]       @relation("TicketAssignee")
  createdRewards CustomerReward[] @relation("RewardCreatedBy")
  createdVouchers    Voucher[]          @relation("VoucherCreatedBy")
  assignedVouchers   CustomerVoucher[]  @relation("VoucherAssignedBy")
  openedDeals           Deal[]             @relation("DealOpenedBy")
  closedDeals           Deal[]             @relation("DealClosedBy")
  createdCampaigns      Campaign[]         @relation("CampaignCreatedBy")
  addedCampaignMembers  CampaignMember[]   @relation("CampaignMemberAddedBy")
  campaignComments      CampaignComment[]  @relation("CampaignCommentUser")

  @@map("users")
}

model Brand {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  domain      String?
  settings    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBrands  UserBrand[]
  roles       Role[]
  customers   Customer[]
  leads       Lead[]
  deals       Deal[]
  campaigns   Campaign[]
  tickets     Ticket[]
  vouchers    Voucher[]
  auditLogs   AuditLog[]
  activities  Activity[]
  notifications Notification[]

  @@map("brands")
}

model Role {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand           Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userBrands      UserBrand[]

  @@unique([brandId, name])
  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserBrand {
  id      String @id @default(cuid())
  userId  String
  brandId String
  roleId  String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@map("user_brands")
}

// ============================================================
// CUSTOMER MANAGEMENT
// ============================================================

model Customer {
  id           String   @id @default(cuid())
  brandId      String
  assignedTo   String?
  name         String
  titlePrefix  String?
  firstName    String?
  lastName     String?
  nickname     String?
  sex          String?
  email        String?
  phone        String?
  source       String?
  stage        String?  @default("new") // new, contacted, qualified, converted, lost
  interest     String?
  birthDate    String?
  idCard       String?
  customerAddress String?
  address      String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  company      String?
  tags         String[] @default([])
  notes        String?
  status       String   @default("active") // active, inactive, prospect
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand      Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  leads      Lead[]
  tickets    Ticket[]
  activities Activity[]
  deals      Deal[]
  addresses         CustomerAddress[]
  jobs              CustomerJob[]
  education         CustomerEducation[]
  emergencyContacts CustomerEmergencyContact[]
  medical           CustomerMedical[]
  diving            CustomerDiving[]
  socials           CustomerSocial[]
  files             CustomerFile[]
  rewards           CustomerReward[]
  customerVouchers  CustomerVoucher[]
  campaignMembers   CampaignMember[]

  @@index([brandId])
  @@index([brandId, assignedTo])
  @@index([brandId, email])
  @@map("customers")
}

// ============================================================
// SALES MANAGEMENT
// ============================================================

model Lead {
  id           String   @id @default(cuid())
  brandId      String
  customerId   String?
  assignedToId String?
  createdById  String?
  title        String
  titlePrefix  String?
  firstName    String?
  lastName     String?
  nickname     String?
  sex          String?
  phone        String?
  email        String?
  interest     String?
  source       String?
  status       String   @default("new") // new, contacted, qualified, unqualified
  stage        String   @default("prospecting") // prospecting, qualification, proposal, negotiation, closed_won, closed_lost
  birthDate    String?
  idCard       String?
  address      String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  notes        String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand      Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?     @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  deals      Deal[]
  activities Activity[]
  addresses         CustomerAddress[]
  jobs              CustomerJob[]
  education         CustomerEducation[]
  emergencyContacts CustomerEmergencyContact[]
  medical           CustomerMedical[]
  diving            CustomerDiving[]
  socials           CustomerSocial[]
  files             CustomerFile[]
  campaignMembers   CampaignMember[]

  @@index([brandId])
  @@index([brandId, stage])
  @@index([brandId, assignedToId])
  @@map("leads")
}

model Deal {
  id          String   @id @default(cuid())
  brandId     String
  leadId      String?
  customerId  String?
  openedById  String?
  closedById  String?
  title       String
  value       Float
  stage       String   @default("proposal")
  probability Int      @default(50)
  expectedCloseDate DateTime?
  openedAt    DateTime @default(now())
  closedAt    DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  openedBy User?     @relation("DealOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  closedBy User?     @relation("DealClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@index([brandId, stage])
  @@map("deals")
}

// ============================================================
// MARKETING
// ============================================================

model Campaign {
  id          String   @id @default(cuid())
  brandId     String
  createdById String?
  name        String
  type        String   // email, sms, social, event, custom
  status      String   @default("draft") // draft, scheduled, running, completed, paused
  description String?
  subject     String?
  content     String?
  targetSegment Json?
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  scheduledAt DateTime?
  sentAt      DateTime?
  stats       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand     Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  stages    CampaignStage[]
  members   CampaignMember[]

  @@index([brandId])
  @@map("campaigns")
}

model CampaignStage {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  color      String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  members  CampaignMember[]

  @@index([campaignId])
  @@map("campaign_stages")
}

model CampaignMember {
  id          String    @id @default(cuid())
  campaignId  String
  stageId     String?
  customerId  String?
  leadId      String?
  status      String    @default("added")
  addedVia    String    @default("add") // add, import, ai
  notes       String?
  description String?
  priority    String    @default("medium")
  dueDate     DateTime?
  labels      Json?
  addedById   String?
  addedAt     DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  campaign    Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stage       CampaignStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  customer    Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead        Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  addedBy     User?          @relation("CampaignMemberAddedBy", fields: [addedById], references: [id], onDelete: SetNull)
  checklists  CampaignChecklist[]
  comments    CampaignComment[]
  attachments CampaignAttachment[]

  @@unique([campaignId, customerId])
  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([stageId])
  @@index([customerId])
  @@index([leadId])
  @@map("campaign_members")
}

model CampaignChecklist {
  id        String   @id @default(cuid())
  memberId  String
  text      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  member CampaignMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("campaign_checklists")
}

model CampaignComment {
  id        String   @id @default(cuid())
  memberId  String
  userId    String
  text      String
  createdAt DateTime @default(now())

  member CampaignMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  user   User           @relation("CampaignCommentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("campaign_comments")
}

model CampaignAttachment {
  id        String   @id @default(cuid())
  memberId  String
  fileName  String
  fileUrl   String
  fileSize  Int      @default(0)
  createdAt DateTime @default(now())

  member CampaignMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("campaign_attachments")
}

// ============================================================
// SUPPORT
// ============================================================

model Ticket {
  id          String   @id @default(cuid())
  brandId     String
  customerId  String?
  assigneeId  String?
  subject     String
  description String?
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("open")   // open, in_progress, waiting, resolved, closed
  category    String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignee User?     @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@index([brandId, status])
  @@map("tickets")
}

// ============================================================
// SHARED: ACTIVITY, AUDIT, NOTIFICATIONS
// ============================================================

model Activity {
  id         String   @id @default(cuid())
  brandId    String
  userId     String?
  customerId String?
  leadId     String?
  entityType String   // customer, lead, deal, ticket
  entityId   String
  type       String   // note, call, email, meeting, status_change, assignment
  title      String
  description String?
  metadata   Json?
  createdAt  DateTime @default(now())

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([brandId, entityType, entityId])
  @@map("activities")
}

model AuditLog {
  id        String   @id @default(cuid())
  brandId   String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@index([userId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  brandId   String?
  userId    String
  type      String   // info, warning, success, assignment, reminder
  title     String
  message   String?
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// CUSTOMER EXTENDED DATA
// ============================================================

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String?
  leadId     String?
  type       String?
  street     String?
  city       String?
  state      String?
  postalCode String?
  country    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([leadId])
  @@map("customer_addresses")
}

model CustomerJob {
  id         String    @id @default(cuid())
  customerId String?
  leadId     String?
  company    String?
  position   String?
  startDate  String?
  endDate    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([leadId])
  @@map("customer_jobs")
}

model CustomerEducation {
  id          String   @id @default(cuid())
  customerId  String?
  leadId      String?
  institution String?
  degree      String?
  field       String?
  startYear   String?
  endYear     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([leadId])
  @@map("customer_education")
}

model CustomerEmergencyContact {
  id           String   @id @default(cuid())
  customerId   String?
  leadId       String?
  name         String?
  relationship String?
  phone        String?
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([leadId])
  @@map("customer_emergency_contacts")
}

model CustomerMedical {
  id          String   @id @default(cuid())
  customerId  String?
  leadId      String?
  bloodType   String?
  allergies   String?
  conditions  String?
  medications String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([leadId])
  @@map("customer_medical")
}

model CustomerDiving {
  id            String   @id @default(cuid())
  customerId    String?
  leadId        String?
  certLevel     String?
  licenseNumber String?
  diveCount     Int?
  lastDiveDate  String?
  instructor    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([leadId])
  @@map("customer_diving")
}

model CustomerSocial {
  id         String   @id @default(cuid())
  customerId String?
  leadId     String?
  platform   String?
  handle     String?
  url        String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([leadId])
  @@map("customer_socials")
}

model CustomerFile {
  id         String   @id @default(cuid())
  customerId String?
  leadId     String?
  fileName   String
  fileUrl    String
  fileType   String?
  fileSize   Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([leadId])
  @@map("customer_files")
}

model CustomerReward {
  id          String   @id @default(cuid())
  customerId  String
  type        String   // point
  amount      Int
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("RewardCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([customerId, type])
  @@map("customer_rewards")
}

model Voucher {
  id          String    @id @default(cuid())
  brandId     String
  name        String
  code        String?
  type        String    @default("fixed_amount") // fixed_amount, percentage, free_item
  value       Float?
  description String?
  coverUrl    String?
  minPurchase Float?
  maxDiscount Float?
  usageLimit  Int?
  usedCount   Int       @default(0)
  startDate   DateTime?
  expiryDate  DateTime?
  status      String    @default("active") // active, inactive, expired
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  brand     Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("VoucherCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  customerVouchers CustomerVoucher[]
  images           VoucherImage[]

  @@index([brandId])
  @@index([brandId, status])
  @@index([code])
  @@map("vouchers")
}

model VoucherImage {
  id        String   @id @default(cuid())
  voucherId String
  fileName  String
  fileUrl   String
  fileSize  Int?
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@map("voucher_images")
}

model CustomerVoucher {
  id           String    @id @default(cuid())
  customerId   String
  voucherId    String
  quantity     Int       @default(1)
  status       String    @default("assigned") // assigned, used, expired
  assignedById String?
  usedAt       DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  voucher    Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  assignedBy User?    @relation("VoucherAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([voucherId])
  @@map("customer_vouchers")
}

// ============================================================
// CONFIGURATION
// ============================================================

model Source {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
  @@map("sources")
}
