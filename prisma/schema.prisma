generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH & MULTI-TENANT
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  fullName      String
  avatarUrl     String?
  isSuperAdmin  Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userBrands    UserBrand[]
  auditLogs     AuditLog[]
  activities    Activity[]
  notifications Notification[]
  assignedLeads Lead[]         @relation("AssignedTo")
  createdLeads  Lead[]         @relation("CreatedBy")
  tickets       Ticket[]       @relation("TicketAssignee")

  @@map("users")
}

model Brand {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  domain      String?
  settings    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBrands  UserBrand[]
  roles       Role[]
  customers   Customer[]
  leads       Lead[]
  deals       Deal[]
  campaigns   Campaign[]
  tickets     Ticket[]
  auditLogs   AuditLog[]
  activities  Activity[]
  notifications Notification[]

  @@map("brands")
}

model Role {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand           Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userBrands      UserBrand[]

  @@unique([brandId, name])
  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserBrand {
  id      String @id @default(cuid())
  userId  String
  brandId String
  roleId  String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@map("user_brands")
}

// ============================================================
// CUSTOMER MANAGEMENT
// ============================================================

model Customer {
  id           String   @id @default(cuid())
  brandId      String
  assignedTo   String?
  name         String
  firstName    String?
  lastName     String?
  email        String?
  phone        String?
  source       String?
  stage        String?  @default("new") // new, contacted, qualified, converted, lost
  interest     String?
  birthDate    String?
  idCard       String?
  customerAddress String?
  company      String?
  address      String?
  city         String?
  country      String?
  tags         String[] @default([])
  notes        String?
  status       String   @default("active") // active, inactive, prospect
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand      Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  leads      Lead[]
  tickets    Ticket[]
  activities Activity[]
  deals      Deal[]
  addresses         CustomerAddress[]
  jobs              CustomerJob[]
  education         CustomerEducation[]
  emergencyContacts CustomerEmergencyContact[]
  medical           CustomerMedical[]
  diving            CustomerDiving[]

  @@index([brandId])
  @@index([brandId, assignedTo])
  @@index([brandId, email])
  @@map("customers")
}

// ============================================================
// SALES MANAGEMENT
// ============================================================

model Lead {
  id           String   @id @default(cuid())
  brandId      String
  customerId   String?
  assignedToId String?
  createdById  String?
  title        String
  firstName    String?
  lastName     String?
  phone        String?
  email        String?
  interest     String?
  source       String?
  status       String   @default("new") // new, contacted, qualified, unqualified
  stage        String   @default("prospecting") // prospecting, qualification, proposal, negotiation, closed_won, closed_lost
  notes        String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand      Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?     @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  deals      Deal[]
  activities Activity[]

  @@index([brandId])
  @@index([brandId, stage])
  @@index([brandId, assignedToId])
  @@map("leads")
}

model Deal {
  id          String   @id @default(cuid())
  brandId     String
  leadId      String?
  customerId  String?
  title       String
  value       Float
  stage       String   @default("proposal") // proposal, negotiation, contract, closed_won, closed_lost
  probability Int      @default(50)
  expectedCloseDate DateTime?
  closedAt    DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@index([brandId, stage])
  @@map("deals")
}

// ============================================================
// MARKETING
// ============================================================

model Campaign {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  type        String   // email, sms, social
  status      String   @default("draft") // draft, scheduled, running, completed, paused
  subject     String?
  content     String?
  targetSegment Json?
  budget      Float?
  scheduledAt DateTime?
  sentAt      DateTime?
  stats       Json?    // { sent, opened, clicked, converted }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@map("campaigns")
}

// ============================================================
// SUPPORT
// ============================================================

model Ticket {
  id          String   @id @default(cuid())
  brandId     String
  customerId  String?
  assigneeId  String?
  subject     String
  description String?
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("open")   // open, in_progress, waiting, resolved, closed
  category    String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignee User?     @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@index([brandId, status])
  @@map("tickets")
}

// ============================================================
// SHARED: ACTIVITY, AUDIT, NOTIFICATIONS
// ============================================================

model Activity {
  id         String   @id @default(cuid())
  brandId    String
  userId     String?
  customerId String?
  leadId     String?
  entityType String   // customer, lead, deal, ticket
  entityId   String
  type       String   // note, call, email, meeting, status_change, assignment
  title      String
  description String?
  metadata   Json?
  createdAt  DateTime @default(now())

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([brandId, entityType, entityId])
  @@map("activities")
}

model AuditLog {
  id        String   @id @default(cuid())
  brandId   String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@index([userId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  brandId   String?
  userId    String
  type      String   // info, warning, success, assignment, reminder
  title     String
  message   String?
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// CUSTOMER EXTENDED DATA
// ============================================================

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  type       String?
  street     String?
  city       String?
  state      String?
  postalCode String?
  country    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model CustomerJob {
  id         String    @id @default(cuid())
  customerId String
  company    String?
  position   String?
  startDate  String?
  endDate    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_jobs")
}

model CustomerEducation {
  id          String   @id @default(cuid())
  customerId  String
  institution String?
  degree      String?
  field       String?
  startYear   String?
  endYear     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_education")
}

model CustomerEmergencyContact {
  id           String   @id @default(cuid())
  customerId   String
  name         String?
  relationship String?
  phone        String?
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_emergency_contacts")
}

model CustomerMedical {
  id          String   @id @default(cuid())
  customerId  String
  bloodType   String?
  allergies   String?
  conditions  String?
  medications String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_medical")
}

model CustomerDiving {
  id            String   @id @default(cuid())
  customerId    String
  certLevel     String?
  licenseNumber String?
  diveCount     Int?
  lastDiveDate  String?
  instructor    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_diving")
}

// ============================================================
// CONFIGURATION
// ============================================================

model Source {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
  @@map("sources")
}
